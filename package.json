{
  "name": "nexasos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "cd nexasos && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install:all": "npm install && cd nexasos && npm install && cd ../backend && npm install",
    "setup": "bash scripts/setup.sh",
    "build:frontend": "cd nexasos && npm run build",
    "build:backend": "cd backend && npm run build",
    "build": "sh scripts/railway-build.sh",
    "test": "cd backend && npm test",
    "test:backend": "cd backend && npm test",
    "start:frontend": "cd nexasos && npm run start",
    "start:backend": "cd backend && npm start",
    "start": "sh scripts/railway-start.sh"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
