# NEXUS OS API — Environment Variables
# Copy to backend/.env — only API keys remain to configure

PORT=4000
NODE_ENV=development
JWT_SECRET=change_this_in_production
ENCRYPTION_KEY=change_this_for_t2_t3_encryption

# Database (leave empty for local SQLite)
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── AI Model Router (at least GEMINI recommended) ──
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TYPHOON_API_KEY=
TYPHOON_API_URL=https://api.opentyphoon.ai/v1/chat/completions

# ── Email notifications (optional) ──
# Resend (recommended) OR SMTP
RESEND_API_KEY=
EMAIL_FROM=NEXUS OS <notify@yourdomain.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── LINE OA (optional — staff work log + push notify) ──
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_DEFAULT_COMPANY_ID=

# ── CORS ──
FRONTEND_URL=http://localhost:3000,http://localhost:3002

# ── Ops (auto) ──
# Backups → backend/data/backups/
# File storage → backend/data/storage/
